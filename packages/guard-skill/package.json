{
  "name": "@pharos-guard/guard-skill",
  "version": "0.1.0",
  "private": true,
  "description": "tx-guard core — chain definition and the transaction firewall that vets AI-agent transactions before signing.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
