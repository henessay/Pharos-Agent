# ---------------------------------------------------------------------------
# Pharos Guard — environment configuration
# Copy this file to `.env` and fill in real values. Never commit `.env`.
# ---------------------------------------------------------------------------

# Pharos Testnet JSON-RPC endpoint (chain id 688688)
PHAROS_RPC_URL=https://testnet.dplabs-internal.com

# Deployer / agent signer private key (without quotes).
# ⚠️ Use a throwaway testnet key. Never commit a real key to version control.
PRIVATE_KEY=

# Pharos Testnet block explorer base URL
EXPLORER_URL=https://testnet.pharosscan.xyz

# Agent address granted execution rights on TreasuryPolicy (set at deploy time).
AGENT_ADDRESS=

# Deployed contract addresses (filled after running the deploy scripts).
# POLICY_ADDRESS is the TreasuryPolicy contract.
POLICY_ADDRESS=
GUARDLOG_ADDRESS=
